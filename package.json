{
  "name": "cenro",
  "version": "0.1.0",
  "private": false,
  "description": "Cenro is a Windows-first local AI workspace for coding, research, and learning.",
  "author": "Cenro contributors",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "npm run build:desktop",
    "build:desktop": "tsc -p tsconfig.main.json && vite build",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "check": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "package:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.53.0",
    "openai": "^6.48.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-builder-squirrel-windows": "^26.15.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.cenro.workspace",
    "productName": "Cenro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/cenro.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Cenro-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Cenro-${version}-portable.${ext}"
    }
  }
}
